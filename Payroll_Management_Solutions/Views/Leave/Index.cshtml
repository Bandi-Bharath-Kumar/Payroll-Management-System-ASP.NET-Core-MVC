@model IEnumerable<LeaveRequest>
@{
    ViewData["Title"] = "Leave Requests";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Leave Requests</h3>
    </div>

    <div class="card">
        <div class="card-body">
            <table class="table table-hover align-middle table-dark-custom">
                <thead class="table-dark">
                    <tr>
                        <th>Employee</th>
                        <th>From</th>
                        <th>To</th>
                        <th>Reason</th>
                        <th>Status</th>
                        <th>Requested On</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td>@r.Employee.FullName</td>
                            <td>@r.FromDate.ToString("dd-MMM-yyyy")</td>
                            <td>@r.ToDate.ToString("dd-MMM-yyyy")</td>
                            <td>@r.Reason</td>
                            <td>
                                @switch (r.Status)
                                {
                                    case LeaveStatus.Pending:
                                        <span class="badge bg-warning text-dark">Pending</span>
                                        break;
                                    case LeaveStatus.Approved:
                                        <span class="badge bg-success">Approved</span>
                                        break;
                                    case LeaveStatus.Rejected:
                                        <span class="badge bg-danger">Rejected</span>
                                        break;
                                }
                            </td>
                            <td>@r.RequestedOn.ToString("dd-MMM-yyyy hh:mm tt")</td>
                            <td class="text-end">
                                @if (r.Status == LeaveStatus.Pending)
                                {
                                    <form asp-action="Approve" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@r.LeaveRequestId" />
                                        <button type="submit" class="btn btn-success btn-sm">Approve</button>
                                    </form>
                                    <form asp-action="Reject" method="post" class="d-inline ms-1">
                                        <input type="hidden" name="id" value="@r.LeaveRequestId" />
                                        <button type="submit" class="btn btn-danger btn-sm">Reject</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

