@model LeaveRequest
@{
    ViewData["Title"] = "Request Leave";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-body">
            <h3 class="mb-3">Request Leave</h3>

            <form asp-action="Request" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="FromDate" class="form-label">From Date</label>
                        <input asp-for="FromDate" type="date" class="form-control" />
                        <span asp-validation-for="FromDate" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ToDate" class="form-label">To Date</label>
                        <input asp-for="ToDate" type="date" class="form-control" />
                        <span asp-validation-for="ToDate" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-3">
                    <label asp-for="Reason" class="form-label">Reason</label>
                    <textarea asp-for="Reason" rows="3" class="form-control"></textarea>
                    <span asp-validation-for="Reason" class="text-danger"></span>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Submit Request</button>
                    <a asp-action="MyRequests" class="btn btn-secondary ms-2">My Requests</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

