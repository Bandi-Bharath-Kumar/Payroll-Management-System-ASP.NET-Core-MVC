@model IEnumerable<LeaveRequest>
@{
    ViewData["Title"] = "My Leave Requests";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">My Leave Requests</h3>
        <a asp-action="Request" class="btn btn-primary btn-sm">New Request</a>
    </div>

    <div class="card">
        <div class="card-body">
            <table class="table table-hover align-middle table-dark-custom">
                <thead class="table-dark">
                    <tr>
                        <th>From</th>
                        <th>To</th>
                        <th>Reason</th>
                        <th>Status</th>
                        <th>Requested On</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td>@r.FromDate.ToString("dd-MMM-yyyy")</td>
                            <td>@r.ToDate.ToString("dd-MMM-yyyy")</td>
                            <td>@r.Reason</td>
                            <td>
                                @switch (r.Status)
                                {
                                    case LeaveStatus.Pending:
                                        <span class="badge bg-warning text-dark">Pending</span>
                                        break;
                                    case LeaveStatus.Approved:
                                        <span class="badge bg-success">Approved</span>
                                        break;
                                    case LeaveStatus.Rejected:
                                        <span class="badge bg-danger">Rejected</span>
                                        break;
                                }
                            </td>
                            <td>@r.RequestedOn.ToString("dd-MMM-yyyy hh:mm tt")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

