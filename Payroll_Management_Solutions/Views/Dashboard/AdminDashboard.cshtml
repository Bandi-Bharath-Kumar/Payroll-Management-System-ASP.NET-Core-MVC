@model Payroll_Management_Solutions.Models.ViewModels.AdminDashboardVM
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid mt-3">
    <div class="dashboard-shell">
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
            <div>
                <h2 class="mb-1">Admin Dashboard</h2>
                <p class="text-muted mb-0">Overview of people, payroll and attendance.</p>
            </div>
            <div class="dashboard-user-pill">
                <span class="me-2">👋</span>
                <div>
                    @{
                        var fullName = User.FindFirst("FullName")?.Value ?? User.Identity.Name;
                        var firstName = (fullName ?? string.Empty).Split(' ')[0];
                    }
                    <div class="small text-muted">Welcome back</div>
                    <div class="fw-semibold">@firstName</div>
                </div>
            </div>
        </div>

        <!-- Top metrics row -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="stat-card stat-card-employees">
                    <div class="stat-label">Total Employees</div>
                    <div class="stat-value">@Model.TotalEmployees</div>
                    <div class="stat-subtext">Active across all departments</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card stat-card-approvals">
                    <div class="stat-label">Pending Approvals</div>
                    <div class="stat-value">@Model.PendingApprovals</div>
                    <div class="stat-subtext">Payroll items awaiting review</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card stat-card-hr">
                    <div class="stat-label">HR Members</div>
                    <div class="stat-value">@Model.HrMembers</div>
                    <div class="stat-subtext">Managing people and policies</div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Main action cards -->
            <div class="col-lg-8">
                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="card dashboard-shortcut-card text-start h-100 px-3 py-4">
                            <div class="mb-2 small text-muted">People</div>
                            <h5 class="mb-2">Employees</h5>
                            <p class="mb-3 small">
                                Manage employee profiles, roles and details.
                            </p>
                            <a asp-controller="Employees" asp-action="Index" class="btn btn-primary btn-sm">
                                Manage Employees
                            </a>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card dashboard-shortcut-card text-start h-100 px-3 py-4">
                            <div class="mb-2 small text-muted">Finance</div>
                            <h5 class="mb-2">Payroll</h5>
                            <p class="mb-3 small">
                                Review, generate and approve payroll records.
                            </p>
                            <a asp-controller="Payroll" asp-action="Index" class="btn btn-success btn-sm">
                                Manage Payroll
                            </a>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card dashboard-shortcut-card text-start h-100 px-3 py-4">
                            <div class="mb-2 small text-muted">Presence</div>
                            <h5 class="mb-2">Attendance</h5>
                            <p class="mb-3 small">
                                Track attendance and working hours.
                            </p>
                            <a asp-controller="Attendance" asp-action="Index" class="btn btn-warning btn-sm text-dark">
                                Manage Attendance
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Today events card -->
            <div class="col-lg-4">
                <div class="card h-100 px-3 py-4">
                    <div class="d-flex align-items-center mb-3">
                        <span class="me-2">📅</span>
                        <div>
                            <h5 class="mb-0">Events</h5>
                            <small class="text-muted">Key items for your day</small>
                        </div>
                    </div>

                    @if (Model.TodayEvents != null && Model.TodayEvents.Any())
                    {
                        <div class="admin-events-scroll">
                            @foreach (var ev in Model.TodayEvents)
                            {
                                var timeLabel = ev.CreatedDate.ToString("hh:mm tt");
                                <div class="event-item mb-3">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <div class="fw-semibold">@ev.Title</div>
                                            <small class="text-muted">@ev.Message</small>
                                        </div>
                                        <span class="badge rounded-pill bg-primary-subtle text-primary-emphasis d-inline-flex align-items-center justify-content-center">
                                            @timeLabel
                                        </span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-muted small">
                            No events scheduled for today.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>









