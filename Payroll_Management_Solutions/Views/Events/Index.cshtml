@model IEnumerable<Notifications>
@{
    ViewData["Title"] = "Events";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Events</h2>
        @if (User.IsInRole("Admin") || User.IsInRole("HR"))
        {
            <a asp-action="Create" class="btn btn-primary btn-sm">Add Event</a>
        }
    </div>

    <div class="card">
        <div class="card-body">
            <table class="table table-striped table-hover align-middle table-dark-custom">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Message</th>
                        <th>Date &amp; Time</th>
                        @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                        {
                            <th></th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ev in Model)
                    {
                        <tr>
                            <td>@ev.Title</td>
                            <td>@ev.Message</td>
                            <td>@ev.CreatedDate.ToString("dd-MMM-yyyy hh:mm tt")</td>
                            @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                            {
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@ev.NotificationId" class="btn btn-primary btn-sm me-2">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@ev.NotificationId" class="btn btn-danger btn-sm">Delete</a>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

