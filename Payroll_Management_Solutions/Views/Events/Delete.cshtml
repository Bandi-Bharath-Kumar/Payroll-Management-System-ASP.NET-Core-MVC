@model Notifications
@{
    ViewData["Title"] = "Delete Event";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-body">
            <h3 class="mb-3">Delete Event</h3>
            <p>Are you sure you want to delete this event?</p>

            <dl class="row">
                <dt class="col-sm-3">Title</dt>
                <dd class="col-sm-9">@Model.Title</dd>

                <dt class="col-sm-3">Message</dt>
                <dd class="col-sm-9">@Model.Message</dd>

                <dt class="col-sm-3">Date &amp; Time</dt>
                <dd class="col-sm-9">@Model.CreatedDate.ToString("dd-MMM-yyyy hh:mm tt")</dd>
            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="NotificationId" />
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>

