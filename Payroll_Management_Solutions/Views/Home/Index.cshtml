@{
    ViewData["Title"] = "Home";
    var section = Context.Request.Query["section"].ToString().ToLower();
}

<!-- HERO SECTION (ALWAYS SHOW) -->
<section class="bg-light py-5  text-center">
    <div class="container">
        <h1 class="display-5 fw-bold">Payroll Management Solutions</h1>
        <p class="lead mt-3">
            Smart, secure & scalable payroll software for modern businesses
        </p>
        <div class="mt-4">
            <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg me-2">
                Get Started
            </a>
            <a asp-controller="Home"
               asp-action="Index"
               asp-route-section="about"
               class="btn btn-outline-secondary btn-lg">
                Learn More
            </a>
        </div>
    </div>
</section>

<!-- FEATURES SECTION (ALWAYS SHOW) -->
<section class="py-5 border-bottom">
    <div class="container">
        <div class="row text-center g-4">
            <div class="col-md-4">
                <a asp-controller="Account" asp-action="Login" class="text-decoration-none text-reset d-block h-100">
                    <i class="bi bi-shield-check fs-1 text-primary"></i>
                    <h5 class="mt-3">Secure Payroll</h5>
                    <p>Enterprise-grade security for employee data and salary processing.</p>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="Account" asp-action="Login" class="text-decoration-none text-reset d-block h-100">
                    <i class="bi bi-graph-up fs-1 text-success"></i>
                    <h5 class="mt-3">Automated Reports</h5>
                    <p>Generate payslips, tax and attendance reports in seconds.</p>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="Account" asp-action="Login" class="text-decoration-none text-reset d-block h-100">
                    <i class="bi bi-people fs-1 text-warning"></i>
                    <h5 class="mt-3">HR Friendly</h5>
                    <p>Easy employee management with roles and permissions.</p>
                </a>
            </div>
        </div>
    </div>
</section>

<!-- DYNAMIC CONTENT SECTION (BELOW HERO + FEATURES) -->
@if (!string.IsNullOrEmpty(section))
{
    <section id="home-section-block" class="pt-2 pb-4 text-center">
        <div class="container">
            @switch (section)
            {
                case "about":
                    @await Html.PartialAsync("~/Views/Home/Partials/_AboutPartial.cshtml")
                    break;

                case "features":
                    @await Html.PartialAsync("~/Views/Home/Partials/_FeaturesPartial.cshtml")
                    break;

                case "terms":
                    @await Html.PartialAsync("~/Views/Home/Partials/_TermsPartial.cshtml")
                    break;

                case "privacy":
                    @await Html.PartialAsync("~/Views/Home/Partials/_PrivacyPartial.cshtml")
                    break;

                case "sitemap":
                    @await Html.PartialAsync("~/Views/Home/Partials/_SiteMapPartial.cshtml")
                    break;

                case "contact":
                    @await Html.PartialAsync("~/Views/Home/Partials/_ContactPartial.cshtml")
                    break;
            }
        </div>
    </section>
}

<!-- SOFT CTA STRIP -->
<section class="bg-blue border-top py-5 mt-4">
    <div class="container text-center">
        <h4 class="fw-bold">Ready to simplify payroll?</h4>
        <p class="text-muted mt-2">
            Explore features or request access to experience the platform.
        </p>
        <a asp-controller="Account" asp-action="Login"
           class="btn btn-primary me-2">
            Get Started
        </a>

        <a class="btn btn-warning btn-sm"
           asp-controller="Home" asp-action="Maintainance">
            Request Access
        </a>
    </div>
</section>

