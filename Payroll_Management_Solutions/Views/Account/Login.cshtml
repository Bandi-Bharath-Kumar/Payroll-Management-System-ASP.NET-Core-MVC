@model Payroll_Management_Solutions.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" ng-app="loginApp">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>CogniHub | Login</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- AngularJS (for binding/demo purposes) -->
    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />

    <style>
        body {
            height: 100vh;
            margin: 0;
            background: radial-gradient(circle at top left, #1d4ed8 0, #020617 45%, #000000 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            color: #e5e7eb;
        }

        .login-shell {
            width: 100%;
            max-width: 460px;
            padding-inline: 1.5rem;
        }

        .login-card {
            background: radial-gradient(circle at top left, rgba(15, 23, 42, 0.98), rgba(15, 23, 42, 0.94));
            border-radius: 22px;
            padding: 34px 30px 30px;
            box-shadow: 0 24px 60px rgba(15, 23, 42, 0.9), 0 0 0 1px rgba(148, 163, 184, 0.35);
            border: 1px solid rgba(148, 163, 184, 0.55);
        }

        .brand-title {
            font-size: 24px;
            font-weight: 700;
            text-align: center;
            letter-spacing: 0.04em;
        }

        .brand-subtitle {
            font-size: 14px;
            color: #9ca3af;
            text-align: center;
            margin-top: 6px;
            margin-bottom: 26px;
        }

        .form-floating > .form-control {
            background-color: rgba(15, 23, 42, 0.9);
            border-radius: 12px;
            border-color: rgba(148, 163, 184, 0.55);
            color: #e5e7eb;
        }

            .form-floating > .form-control:focus {
                background-color: rgba(15, 23, 42, 0.98);
                border-color: rgba(129, 140, 248, 0.9);
                box-shadow: 0 0 0 1px rgba(129, 140, 248, 0.7);
            }

        .form-floating > label {
            color: #9ca3af;
        }

        .form-floating > .form-control:focus ~ label {
            color: #111827;
            font-weight: 600;
        }

        .form-floating > .form-control:not(:placeholder-shown) ~ label {
            color: #e5e7eb;
            font-weight: 500;
        }

        .btn-login {
            height: 50px;
            font-weight: 600;
            font-size: 16px;
            border-radius: 999px;
            background: linear-gradient(135deg, #4f46e5, #6366f1);
            border: none;
            box-shadow: 0 14px 35px rgba(79, 70, 229, 0.55);
        }

            .btn-login:hover {
                background: linear-gradient(135deg, #4338ca, #4f46e5);
            }

        .footer-text {
            text-align: center;
            font-size: 12px;
            color: #9ca3af;
            margin-top: 18px;
        }

        .back-home-link {
            position: absolute;
            top: 18px;
            left: 26px;
            border-radius: 999px;
            border-color: rgba(148, 163, 184, 0.7);
            color: #e5e7eb;
            background: rgba(15, 23, 42, 0.6);
            padding-inline: 14px;
            backdrop-filter: blur(6px);
        }

            .back-home-link:hover {
                background: rgba(15, 23, 42, 0.9);
                border-color: #e5e7eb;
                color: #ffffff;
            }

        .password-toggle {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
