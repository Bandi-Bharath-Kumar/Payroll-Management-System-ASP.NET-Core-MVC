@model Payroll_Management_Solutions.Models.Employees

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="EmployeeId" />
@*     <input type="hidden" asp-for="EmployeeCode" /> *@
    <input type="hidden" asp-for="IdentityUserId" />

    <label>Full Name</label>
    <input asp-for="FullName" class="form-control" />

    <label>Email</label>
    <input asp-for="Email" class="form-control" readonly />

    <label>Department</label>
    <input asp-for="Department" class="form-control" />

    <label>Designation</label>
    <input asp-for="Designation" class="form-control" />

    <label>Salary</label>
    <input asp-for="BasicSalary" class="form-control" />

    <label>Role</label>
    <select asp-for="Role" class="form-control"
            asp-items="@(new SelectList(ViewBag.Roles))">
    </select>

    <div class="form-check form-switch mt-3">
        <input class="form-check-input" asp-for="IsActive" />
        <label class="form-check-label" asp-for="IsActive">Active</label>
    </div>

    <br />
    <button type="submit" class="btn btn-primary">Update</button>
</form>

