@model Payroll_Management_Solutions.Models.Employees

@{
    ViewData["Title"] = "My Profile";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <!-- Profile Card -->
            <div class="card shadow-lg border-0">
                <div class="card-header bg-dark text-white d-flex align-items-center">
                    <i class="bi bi-person-circle fs-3 me-2"></i>
                    <h4 class="mb-0">My Profile</h4>
                </div>

                <div class="card-body p-4">
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted fw-bold">Name</div>
                        <div class="col-sm-8">@Model.FullName</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted fw-bold">Email</div>
                        <div class="col-sm-8">@Model.Email</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted fw-bold">Department</div>
                        <div class="col-sm-8">
                            <span class="badge bg-primary">@Model.Department</span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-sm-4 text-muted fw-bold">Designation</div>
                        <div class="col-sm-8">
                            <span class="badge bg-success">@Model.Designation</span>
                        </div>
                    </div>
                </div>

                <div class="card-footer text-end bg-light">
                    <a asp-action="MyAttendance" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-calendar-check"></i> My Attendance
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>






