@model IEnumerable<Payroll_Management_Solutions.Models.Employees>

<div>

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>👥 Employees</h2>
        @* <a href="/Notifications">
            🔔 <span class="badge badge-danger">@ViewBag.UnreadCount</span>
        </a> *@
        <a asp-action="Create" class="btn btn-success">➕ Add New Employee</a>
     
    </div>

    <!-- Scrollable Cards Area -->
    <div class="flex-grow-1 overflow-auto pe-2">
        <div class="row g-3">
            @foreach (var emp in Model)
            {
                <div class="col-md-4">
                    <div class="card shadow h-100">
                        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                            <strong>@emp.FullName</strong>
                            <span class="badge bg-light text-dark">@emp.Role</span>
                        </div>

                        <div class="card-body">
                            <p><strong>Email:</strong> @emp.Email</p>
                            <p><strong>Department:</strong> @emp.Department</p>
                            <p><strong>Designation:</strong> @emp.Designation</p>
                            <p><strong>Salary:</strong> @emp.BasicSalary.ToString("C")</p>
                        </div>

                        <div class="card-footer d-flex justify-content-between">
                            <a asp-action="Edit"
                               asp-route-id="@emp.EmployeeId"
                               class="btn btn-sm btn-warning">✏ Edit</a>

                            <form asp-action="DeleteConfirmed"
                                  asp-route-id="@emp.EmployeeId"
                                  method="post"
                                  onsubmit="return confirm('Are you sure you want to delete @emp.FullName?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger">🗑 Delete</button>
                                @if (string.IsNullOrEmpty(@emp.IdentityUserId))
                                {
                                    <a asp-action="CreateLogin"
                                       asp-route-id="@emp.EmployeeId"
                                       class="btn btn-sm btn-warning">
                                        Create Login
                                    </a>
                                }

                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
