@model IEnumerable<Payroll_Management_Solutions.Models.Attendances>
@using Payroll_Management_Solutions.Models

@{
    ViewData["Title"] = "Attendance Records";
}

<div class="card shadow-sm border-0">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
        <h4 class="mb-2 mb-md-0">Attendance</h4>

        @if (User.IsInRole("Admin") || User.IsInRole("HR"))
        {
            <div class="d-flex gap-2">
                <a asp-action="Mark" class="btn btn-primary btn-sm">
                    <i class="bi bi-calendar-check"></i> Mark Attendance
                </a>

                @*   <a class="btn btn-success btn-sm">Export Excel</a>
                <a class="btn btn-danger btn-sm">Export PDF</a> *@
            </div>
        }
    </div>
    <div class="mb-3 text-end">
        <button class="btn btn-success btn-sm" id="excelExport">
            Export Excel
        </button>
        <button class="btn btn-danger btn-sm" id="pdfExport">
            Export PDF
        </button>
    </div>
    <div class="row g-2 mb-4">
        <div class="col-md-3 col-sm-6">
            <input type="date" id="startDate" class="form-control" />
        </div>

        <div class="col-md-3 col-sm-6">
            <input type="date" id="endDate" class="form-control" />
        </div>

        <div class="col-md-2 col-sm-12">
            <button class="btn btn-outline-primary w-100" id="filterBtn">
                Filter
            </button>
        </div>
    </div>
    <div class="row mb-4 g-3">

        <div class="col-xl-3 col-md-6 col-sm-12">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted">Employees</h6>
                    <h3 id="employeeCount" class="fw-bold">0</h3>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 col-sm-12">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted">Total Days</h6>
                    <h3 id="totalDays" class="fw-bold text-secondary">0</h3>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 col-sm-12">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted">Present</h6>
                    <h3 id="presentDays" class="fw-bold text-success">0</h3>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 col-sm-12">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted">Absent</h6>
                    <h3 id="absentDays" class="fw-bold text-danger">0</h3>
                </div>
            </div>
        </div>

        @*  <div class="col-xl-3 col-md-12 col-sm-12 text-center"> *@
        <div class="col-xl-12 col-md-12 col-sm-12 text-center">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted">Total Hours</h6>
                    <h3 id="totalHours" class="fw-bold text-primary">0</h3>
                </div>
            </div>
        </div>

    </div>
    <div class="card-body">
        <div class="table-responsive">
            <div class="table-responsive">
                <table id="attendanceTable" class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Employee</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>In Time</th>
                            <th>Out Time</th>
                            <th class="text-end">Working Hours</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @if (User.IsInRole("Employee"))
                                    {
                                        <span class="fw-semibold">@item.Employee.FullName</span>
                                    }
                                    else
                                    {
                                        <a href="javascript:void(0)" class="employee-link" data-name="@item.Employee.FullName" data-employeeid="@item.EmployeeId">
                                            @item.Employee.FullName
                                        </a>
                                    }
                                </td>
                                <td data-date="@item.Date.ToString("yyyy-MM-dd")">
                                    @item.Date.ToString("dd-MMM-yyyy")
                                </td>


                                <td>
                                    @if (item.Status == AttendanceStatus.Present)
                                    {
                                        <span class="badge bg-success">Present</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Absent</span>
                                    }
                                </td>

                                <td>@(item.InTime?.ToString(@"hh\:mm") ?? "-")</td>

                                <td>@(item.OutTime?.ToString(@"hh\:mm") ?? "-")</td>

                                <td class="fw-bold">
                                    @item.WorkingHours.ToString("0.00") hrs
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="modal fade" id="employeeModal" tabindex="-1">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title employee-modal-title" id="empName"></h5>
                            <button class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            Employee-wise attendance coming here
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            // SINGLE DataTable
            var table = $('#attendanceTable').DataTable({
                pageLength:16,
                order: [[1, 'desc']],
                dom: 'Bfrtip',
                buttons: ['excelHtml5', 'pdfHtml5']
            });

            // Export
            $('#excelExport').click(() => table.button('.buttons-excel').trigger());
            $('#pdfExport').click(() => table.button('.buttons-pdf').trigger());

            // Date filter (FIXED)
            $.fn.dataTable.ext.search.push(function (settings, data) {
                let start = $('#startDate').val();
                let end = $('#endDate').val();
                let date = data[1]; // Date column text

                if (!start && !end) return true;

                    let rowDate = new Date(date);
                if (start && rowDate < new Date(start)) return false;
                if (end && rowDate > new Date(end)) return false;

            return true;
            });


            $('#filterBtn').click(function () {
                table.draw();
                updateSummary();
            });

            // Modal (delegated event)
            $(document).on('click', '.employee-link', function (e) {
                e.preventDefault();

                let empId = $(this).data('employeeid');
                let empName = $(this).data('name');

                $('#empName').text(empName);
                $('#employeeModal .modal-body').html('<div class="text-center">Loading...</div>');

                new bootstrap.Modal(document.getElementById('employeeModal')).show();

                $.get('/Attendance/EmployeeAttendance', { employeeId: empId }, function (data) {
                    $('#employeeModal .modal-body').html(data);
                });
            });

            // $(document).on('click', '.employee-link', function (e) {
            //     e.preventDefault();
            //     $('#empName').text($(this).data('name'));
            //     new bootstrap.Modal(document.getElementById('employeeModal')).show();
            // });

            // SUMMARY FIX (based on filtered rows)
            function updateSummary() {
                let present = 0, absent = 0, hours = 0;
                let uniqueDates = new Set();
                let uniqueEmployees = new Set();

                table.rows({ filter: 'applied' }).every(function () {
                    let row = this.node();

                    let date = $(row).find('td:eq(1)').text().trim();
                    let employee = $(row).find('td:eq(0)').text().trim();
                    let status = $(row).find('td:eq(2)').text().trim();
                    let h = parseFloat($(row).find('td:eq(5)').text().replace('hrs', '').trim()) || 0;

                    uniqueDates.add(date);
                    uniqueEmployees.add(employee);

                    if (status === 'Present') present++;
                    if (status === 'Absent') absent++;
                    hours += h;
                });

                // ✅ CORRECT VALUES
                $('#totalDays').text(uniqueDates.size);        // 3
                $('#presentDays').text(present);               // 14
                 $('#absentDays').text(absent);                 // 1
                $('#totalHours').text(hours.toFixed(2));

                // New card
                $('#employeeCount').text(uniqueEmployees.size); // 7
            }


            updateSummary();
        });
    </script>
}


